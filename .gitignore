.ssh
.env
.gitconfig
*.log

# Ignore databases and cache inside hermes active data folder
hermes/**/*.db
hermes/**/*.sqlite
hermes/**/*.sqlite3
hermes/**/*.db-shm
hermes/**/*.db-wal
hermes/**/cache/

# Ignore Hermes Agent runtime directories
hermes/.cache/
hermes/.local/
hermes/.npm/
hermes/.ssh/
hermes/audio_cache/
hermes/bin/
hermes/cron/*
!hermes/cron/jobs.json
hermes/gateway/
hermes/home/
hermes/image_cache/
hermes/lsp/
hermes/pairing/
hermes/plans/
hermes/plugins/
hermes/sandboxes/
hermes/sessions/
hermes/skins/
hermes/workspace/
# Keep skills but ignore python cache files inside it
hermes/skills/**/__pycache__/
hermes/skills/**/*.pyc

# Ignore Hermes Agent lock and cache files
hermes/**/.*_snapshot.json
hermes/**/*.lock
hermes/**/auth.lock
hermes/**/channel_directory.json
hermes/**/context_length_cache.yaml
hermes/**/gateway_state.json
hermes/**/models_dev_cache.json
hermes/**/ollama_cloud_models_cache.json
hermes/**/config.yaml

# Ignore Hermes Agent runtime logs
hermes/logs/
hermes/**/*.log

# Ignore container home directory (shell history, wget state, etc.)
hermes/home/

# Ignore browser and runtime caches
hermes/.config/

# Ignore web cache files
hermes/**/.wget-hsts

# Ignore databases inside config/muninn/
config/muninn/*.db
config/muninn/*.db-journal

# Ignore Mnemosyne runtime data (DB, logs, embedding models)
hermes/.hermes/mnemosyne/

# Ignore host-level mnemosyne mount
mnemosyne/

# Runtime artifacts that change on every container start
hermes/.clean_shutdown
hermes/.gitconfig
hermes/gateway.pid
hermes/skills/.bundled_manifest
hermes/skills/.usage.json
