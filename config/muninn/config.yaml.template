model_list:
  # Local Ollama Model
  - model_name: ${OLLAMA_MODEL_NAME}
    litellm_params:
      model: ollama/${OLLAMA_MODEL_NAME}
      api_base: http://ollama:11434
      timeout: 1800
      stream_timeout: 1800

  # DeepSeek API Models (Requires DEEPSEEK_API_KEY env var)
  - model_name: deepseek-v4-flash
    litellm_params:
      model: deepseek/deepseek-v4-flash
      timeout: 600

  - model_name: deepseek-v4-pro
    litellm_params:
      model: deepseek/deepseek-v4-pro
      timeout: 600

  # Intelligent Router Model (Complexity-based routing)
  - model_name: deepseek-v4-intelligent
    litellm_params:
      model: auto_router/complexity_router
      complexity_router_config:
        tiers:
          SIMPLE: deepseek-v4-flash
          MEDIUM: deepseek-v4-flash
          COMPLEX: deepseek-v4-pro
          REASONING: deepseek-v4-pro
      complexity_router_default_model: deepseek-v4-flash

  # Google Gemini Models (API key read from GEMINI_API_KEY environment variable)
  - model_name: gemini-2.5-flash
    litellm_params:
      model: gemini/gemini-2.5-flash
      timeout: 600

  - model_name: gemini-2.5-pro
    litellm_params:
      model: gemini/gemini-2.5-pro
      timeout: 600

general_settings:
  store_prompts_in_spend_logs: true
